[
  {
    "height": 30,
    "position": "top",
    "layer": "top",

    "modules-left": [
      "hyprland/workspaces"
    ],

    "modules-center": [
      "hyprland/window"
    ],

    "modules-right": [
      "hyprland/language",
      "custom/weather",
      "pulseaudio",
      "battery",
      "clock",
      "tray"
    ],

    "hyprland/workspaces": {
      "format": "{icon}",
      "format-icons": {
        "1": "ΎΚρ",
        "2": "ΎΕι",
        "3": "ΎΚΚ",
        "4": "ΎΕκ",
        "5": "ΎΜΗ",
        "6": "ΎΗζ",
        "7": "ΎΕδ",
        "8": "ΎΗ▓",
        "9": "ΎΑΒ",
        "magic": "ΌΜΛ"
      },
      "persistent-workspaces": {
        "*": 9
      },
      "show-special": true,
      "special-visible-only": true
    },

    "hyprland/language": {
      "format-en": "en",
      "format-ru": "ru",
      "format-uk": "ua",
      "min-length": 2
    },

    "pulseaudio": {
      "format": "{icon} {volume}%",
      "format-bluetooth": "{icon} {volume}% ΎΛΦ",
      "format-icons": {
        "default": [
          "ΎΑπ",
          "ΎΑρ"
        ],
        "car": "ΎΗ╣",
        "handsfree": "ΎΨΡ",
        "headphones": "ΎΑξ",
        "headset": "ΎΨΡ",
        "phone": "ΎΓΧ",
        "portable": "ΎΓΧ"
      },
      "format-muted": "ΎΑο",
      "on-click": "pavucontrol"
    },

    "clock": {
      "format": "{:%d.%m.%Y - %H:%M}",
      "format-alt": "{:%A, %B %d at %R}"
    },

    "tray": {
      "icon-size": 14,
      "spacing": 1
    }
  }
]

